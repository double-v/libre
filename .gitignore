# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
nul

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client
/src/generated/

.vercel
.env*

# test artifacts (NEVER commit)
/playwright-report/
/test-results/
/blob-report/
/playwright/.cache/

# local debug/notes
/todo.txt

# third-party agent skills (impeccable etc.) — not project code
/.github/skills/

# marketing drafts / brainstorm / AI prompts (not code)
/pitch-tiktok.html
/pitch-tiktok-vertical.html
/pitch-tiktok-vertical*.html
/tiktok-avatar.html
